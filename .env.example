# ══════════════════════════════════════════════════════════════
# FACTURADOR CMD — Variables de Entorno
# ══════════════════════════════════════════════════════════════
# Copiá este archivo como .env y completá los valores.
# En Vercel, cargá estas mismas variables en Settings > Environment Variables.

# ─── Supabase ───
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Mercado Libre ───
MELI_ACCESS_TOKEN=tu_access_token_de_mercado_libre
MELI_APP_ID=tu_app_id_de_mercado_libre

# ─── AFIP ───
AFIP_CUIT=20000000000
AFIP_CERT_BASE64=base64_del_certificado_afip
AFIP_KEY_BASE64=base64_de_la_clave_privada_afip
AFIP_SDK_TOKEN=token_de_afipsdk.com
AFIP_PTO_VTA=1
AFIP_PRODUCTION=true
AFIP_SANDBOX=false

# ─── Datos del Emisor (aparecen en el PDF y la UI) ───
VITE_EMISOR_RAZON_SOCIAL=APELLIDO NOMBRE
VITE_EMISOR_CUIT=20000000000
VITE_EMISOR_CUIT_FMT=20-00000000-0
VITE_EMISOR_DOMICILIO=CALLE 123, CIUDAD
VITE_EMISOR_INICIO_ACT=01/01/2020
VITE_EMISOR_COND_IVA=Responsable Monotributo
VITE_EMISOR_IIBB=20-00000000-0
VITE_EMISOR_PTO_VTA=1
VITE_EMISOR_TIPO_CBTE=11

# ─── App ───
APP_URL=https://tu-app.vercel.app
